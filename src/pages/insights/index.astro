---
import BaseLayout from "../../layouts/BaseLayout.astro";

const topics = [
  {
    title: "SIP & Telephony",
    text: "Notes on SIP signalling, call control, CTI, CSTA, TAPI, and troubleshooting real communication flows.",
  },
  {
    title: "Contact Center Architecture",
    text: "Thoughts on IVR design, routing strategy, customer journeys, agent workflows, and integration patterns.",
  },
  {
    title: "Applied AI",
    text: "Practical lessons from AI, RAG, MCP, automation, support workflows, and useful enterprise use cases.",
  },
  {
    title: "Technical Leadership",
    text: "Reflections on solving complex problems, supporting teams, building clarity, and growing technical intuition.",
  },
];

const upcomingPosts = [
  "How to think through a complex SIP troubleshooting issue",
  "Designing IVR flows that reduce customer frustration",
  "Why customer context matters across voice, email, and chat",
  "Practical AI ideas for technical support teams",
];
---

<BaseLayout
  title="Insights | Surya Lenka"
  description="Technical insights from Surya Lenka on Unified Communications, Contact Center architecture, SIP, AI, automation, and technical leadership."
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Insights</p>
      <h1>Technical notes, practical lessons, and ideas worth sharing.</h1>
      <p class="intro">
        This space will grow into a collection of articles about enterprise
        communications, Contact Center systems, technical troubleshooting,
        architecture, AI, automation, and leadership.
      </p>
    </div>
  </section>

  <section class="topics-section">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="section-label">Topics I plan to explore</p>
          <h2>Writing grounded in real technical work.</h2>
        </div>

        <p>
          The goal is to share useful thinking, not generic theory. Each post
          should help someone understand a system, a problem, or a practical way
          of approaching a challenge.
        </p>
      </div>

      <div class="topics-grid">
        {topics.map((topic, index) => (
          <article class="topic-card">
            <span>0{index + 1}</span>
            <h3>{topic.title}</h3>
            <p>{topic.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="upcoming-section">
    <div class="shell upcoming-layout">
      <div>
        <p class="section-label">Coming soon</p>
        <h2>First technical articles are being prepared.</h2>
        <p>
          Blog publishing will later be managed through simple Markdown files,
          so adding a new article will not require changing the website design.
        </p>
      </div>

      <div class="post-list">
        {upcomingPosts.map((post, index) => (
          <div>
            <span>{index + 1}</span>
            <p>{post}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="connect-section">
    <div class="shell connect-card">
      <div>
        <p class="section-label">Meanwhile</p>
        <h2>Explore the projects and expertise behind these ideas.</h2>
        <p>
          Until the first articles are published, you can explore the technical
          areas and practical projects already included in this portfolio.
        </p>
      </div>

      <a href="/projects/">Explore Projects →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .shell {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
  }

  .page-hero {
    padding: 92px 0 70px;
    background:
      radial-gradient(circle at 84% 16%, rgba(196, 230, 208, 0.72), transparent 24rem),
      var(--page-bg);
  }

  .eyebrow,
  .section-label {
    margin: 0;
    color: var(--green);
    font-family: "DM Mono", monospace;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 940px;
    margin: 16px 0 22px;
    font-size: clamp(2.7rem, 5.5vw, 4.8rem);
    line-height: 1.05;
    letter-spacing: -0.06em;
  }

  .intro {
    max-width: 780px;
    margin-bottom: 0;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .topics-section,
  .upcoming-section,
  .connect-section {
    padding: 84px 0;
  }

  .topics-section,
  .connect-section {
    background: #ffffff;
  }

  .upcoming-section {
    color: #ffffff;
    background: #18281f;
  }

  .section-heading,
  .upcoming-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.65fr);
    gap: 64px;
    align-items: end;
  }

  .section-heading {
    margin-bottom: 40px;
  }

  .section-heading h2,
  .upcoming-layout h2,
  .connect-card h2 {
    margin: 10px 0 0;
    font-size: clamp(2rem, 3.8vw, 3.1rem);
    line-height: 1.12;
    letter-spacing: -0.05em;
  }

  .section-heading > p {
    margin: 0;
    color: var(--muted);
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }

  .topic-card {
    min-height: 235px;
    padding: 27px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--page-bg);
  }

  .topic-card > span {
    color: var(--green);
    font-family: "DM Mono", monospace;
    font-size: 0.76rem;
  }

  .topic-card h3 {
    margin: 24px 0 10px;
    font-size: 1.18rem;
    letter-spacing: -0.035em;
  }

  .topic-card p {
    margin-bottom: 0;
    color: var(--muted);
    font-size: 0.91rem;
  }

  .upcoming-section .section-label {
    color: #a7d8bb;
  }

  .upcoming-layout > div > p:not(.section-label) {
    max-width: 560px;
    margin: 18px 0 0;
    color: #c9d8cd;
  }

  .post-list {
    display: grid;
    gap: 13px;
  }

  .post-list div {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
  }

  .post-list span {
    display: grid;
    width: 27px;
    height: 27px;
    flex: 0 0 27px;
    place-items: center;
    border-radius: 50%;
    color: #18281f;
    background: #a7d8bb;
    font-size: 0.75rem;
    font-weight: 800;
  }

  .post-list p {
    margin: 0;
    color: #d8e3db;
    font-size: 0.92rem;
  }

  .connect-card {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 28px;
    padding: 38px;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: var(--page-bg);
  }

  .connect-card h2 {
    font-size: 2rem;
  }

  .connect-card p:not(.section-label) {
    max-width: 680px;
    margin: 14px 0 0;
    color: var(--muted);
  }

  .connect-card a {
    flex: 0 0 auto;
    padding: 13px 17px;
    border-radius: 9px;
    color: #ffffff;
    background: var(--green-dark);
    font-size: 0.88rem;
    font-weight: 800;
    text-decoration: none;
  }

  .connect-card a:hover {
    background: var(--green);
  }

  @media (max-width: 820px) {
    .section-heading,
    .upcoming-layout {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }

  @media (max-width: 620px) {
    .topics-grid {
      grid-template-columns: 1fr;
    }

    .connect-card {
      align-items: flex-start;
      flex-direction: column;
      padding: 26px;
    }
  }

  @media (max-width: 520px) {
    .shell {
      width: min(100% - 28px, 1120px);
    }

    .page-hero,
    .topics-section,
    .upcoming-section,
    .connect-section {
      padding: 64px 0;
    }
  }
</style>