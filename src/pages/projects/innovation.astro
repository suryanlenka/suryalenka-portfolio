---
import BaseLayout from "../../layouts/BaseLayout.astro";

const milestones = [
  {
    number: "01",
    title: "Identify a real support problem",
    text: "Focus on a customer or operational challenge where fragmented context, repeated manual effort, or slow investigation affects the experience.",
  },
  {
    number: "02",
    title: "Shape a practical concept",
    text: "Turn the problem into a focused solution that can be explained clearly through a simple workflow, prototype, or demonstration.",
  },
  {
    number: "03",
    title: "Build and validate",
    text: "Create a working proof of concept, test the user flow, and refine the story around measurable value for agents, engineers, or customers.",
  },
  {
    number: "04",
    title: "Present the outcome",
    text: "Communicate the problem, solution, workflow, and expected impact in a way that makes the idea easy to understand.",
  },
];

const lessons = [
  "Start with the workflow, not the technology",
  "Keep the problem statement clear and specific",
  "Show value through a realistic demonstration",
  "Design for the people who will use the solution",
  "Use AI where it adds meaningful context or automation",
  "Treat prototypes as learning tools, not final products",
];

const themes = [
  {
    title: "Customer context",
    text: "Helping support teams understand the customer journey across disconnected interactions and systems.",
  },
  {
    title: "Technical productivity",
    text: "Reducing repetitive investigation effort through clearer signals, summaries, and workflow support.",
  },
  {
    title: "Applied AI",
    text: "Using AI to improve real support and operational experiences instead of creating isolated demonstrations.",
  },
];
---

<BaseLayout
  title="Innovation & Vibeathon | Surya Lenka"
  description="Innovation and Vibeathon work by Surya Lenka, focused on practical AI, customer support workflows, technical productivity, and enterprise communication challenges."
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Project · Innovation & Vibeathon</p>
      <h1>Turning practical ideas into working innovation concepts.</h1>
      <p class="intro">
        My innovation work focuses on real challenges in customer support,
        technical troubleshooting, communication workflows, and applied AI.
        The goal is to move beyond an idea and show how a useful solution could work.
      </p>

      <div class="project-meta">
        <span>Applied AI</span>
        <span>Customer Experience</span>
        <span>Technical Innovation</span>
      </div>
    </div>
  </section>

  <section class="story-section">
    <div class="shell split-layout">
      <div>
        <p class="section-label">The Vibeathon journey</p>
        <h2>From a support challenge to a live prototype.</h2>
      </div>

      <div class="body-copy">
        <p>
          SupportBuddy was developed as an AI Ticketing Intelligence concept for
          a Vibeathon setting. The idea focused on a common support challenge:
          customer interactions often happen across multiple channels, while the
          next agent still needs a fast, useful view of the active story.
        </p>
        <p>
          The project was shortlisted among the top ideas and presented live,
          helping validate that practical AI concepts can be framed around real
          workflows, clear user value, and a working demonstration.
        </p>
      </div>
    </div>
  </section>

  <section class="milestones-section">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="section-label">Innovation process</p>
          <h2>How a useful idea moves from problem to prototype.</h2>
        </div>

        <p>
          Innovation is most useful when it keeps a strong link between the
          original problem, the user workflow, the technical approach, and the
          expected outcome.
        </p>
      </div>

      <div class="milestone-grid">
        {milestones.map((milestone) => (
          <article class="milestone-card">
            <span>{milestone.number}</span>
            <h3>{milestone.title}</h3>
            <p>{milestone.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="themes-section">
    <div class="shell">
      <p class="section-label">Innovation themes</p>

      <div class="themes-grid">
        {themes.map((theme) => (
          <article>
            <h2>{theme.title}</h2>
            <p>{theme.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="learning-section">
    <div class="shell learning-layout">
      <div>
        <p class="section-label">What I learned</p>
        <h2>Good innovation is clear, grounded, and easy to experience.</h2>
      </div>

      <div class="learning-list">
        {lessons.map((lesson) => (
          <div>
            <span>✓</span>
            <p>{lesson}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="next-section">
    <div class="shell next-card">
      <div>
        <p class="section-label">Explore the core concept</p>
        <h2>SupportBuddy: AI Ticketing Intelligence</h2>
        <p>
          See the detailed project page for the multi-channel customer-context
          workflow behind the SupportBuddy concept.
        </p>
      </div>

      <a href="/projects/supportbuddy/">Explore SupportBuddy →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .shell {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
  }

  .page-hero {
    padding: 92px 0 72px;
    background:
      radial-gradient(circle at 84% 16%, rgba(196, 230, 208, 0.72), transparent 24rem),
      var(--page-bg);
  }

  .eyebrow,
  .section-label {
    margin: 0;
    color: var(--green);
    font-family: "DM Mono", monospace;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 930px;
    margin: 16px 0 22px;
    font-size: clamp(2.7rem, 5.5vw, 4.8rem);
    line-height: 1.05;
    letter-spacing: -0.06em;
  }

  .intro {
    max-width: 790px;
    margin-bottom: 0;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .project-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    margin-top: 28px;
  }

  .project-meta span {
    padding: 8px 10px;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: #395444;
    background: #ffffff;
    font-size: 0.8rem;
    font-weight: 750;
  }

  .story-section,
  .milestones-section,
  .themes-section,
  .learning-section,
  .next-section {
    padding: 84px 0;
  }

  .story-section,
  .themes-section,
  .next-section {
    background: #ffffff;
  }

  .milestones-section {
    background: var(--page-bg);
  }

  .learning-section {
    color: #ffffff;
    background: #18281f;
  }

  .split-layout,
  .section-heading,
  .learning-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.65fr);
    gap: 64px;
    align-items: start;
  }

  .split-layout h2,
  .section-heading h2,
  .learning-layout h2,
  .next-card h2 {
    margin: 10px 0 0;
    font-size: clamp(2rem, 3.8vw, 3.1rem);
    line-height: 1.12;
    letter-spacing: -0.05em;
  }

  .body-copy p,
  .section-heading > p {
    color: var(--muted);
  }

  .body-copy p:last-child {
    margin-bottom: 0;
  }

  .section-heading {
    align-items: end;
    margin-bottom: 40px;
  }

  .section-heading > p {
    margin: 0;
  }

  .milestone-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  .milestone-card {
    min-height: 255px;
    padding: 27px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: #ffffff;
  }

  .milestone-card > span {
    color: var(--green);
    font-family: "DM Mono", monospace;
    font-size: 0.76rem;
  }

  .milestone-card h3 {
    margin: 24px 0 10px;
    font-size: 1.16rem;
    line-height: 1.2;
    letter-spacing: -0.035em;
  }

  .milestone-card p {
    margin-bottom: 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .themes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 28px;
  }

  .themes-grid article {
    min-height: 210px;
    padding: 26px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--page-bg);
  }

  .themes-grid h2 {
    margin-bottom: 14px;
    font-size: 1.3rem;
    line-height: 1.2;
    letter-spacing: -0.04em;
  }

  .themes-grid p {
    margin-bottom: 0;
    color: var(--muted);
    font-size: 0.91rem;
  }

  .learning-section .section-label {
    color: #a7d8bb;
  }

  .learning-list {
    display: grid;
    gap: 13px;
  }

  .learning-list div {
    display: flex;
    gap: 12px;
    align-items: center;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
  }

  .learning-list span {
    color: #a7d8bb;
    font-weight: 800;
  }

  .learning-list p {
    margin: 0;
    color: #d8e3db;
    font-size: 0.93rem;
  }

  .next-card {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 28px;
    padding: 38px;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: var(--page-bg);
  }

  .next-card h2 {
    font-size: 2rem;
  }

  .next-card p:not(.section-label) {
    max-width: 650px;
    margin: 14px 0 0;
    color: var(--muted);
  }

  .next-card a {
    flex: 0 0 auto;
    padding: 13px 17px;
    border-radius: 9px;
    color: #ffffff;
    background: var(--green-dark);
    font-size: 0.88rem;
    font-weight: 800;
    text-decoration: none;
  }

  .next-card a:hover {
    background: var(--green);
  }

  @media (max-width: 900px) {
    .split-layout,
    .section-heading,
    .learning-layout {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .milestone-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .themes-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .milestone-grid {
      grid-template-columns: 1fr;
    }

    .next-card {
      align-items: flex-start;
      flex-direction: column;
      padding: 26px;
    }
  }

  @media (max-width: 520px) {
    .shell {
      width: min(100% - 28px, 1120px);
    }

    .page-hero,
    .story-section,
    .milestones-section,
    .themes-section,
    .learning-section,
    .next-section {
      padding: 64px 0;
    }
  }
</style>
