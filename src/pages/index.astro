---
import BaseLayout from "../layouts/BaseLayout.astro";

const expertise = [
  {
    number: "01",
    title: "UC & Contact Center",
    text: "Enterprise communication platforms, contact center solutions, CloudLink, workflow design, and customer interaction systems.",
  },
  {
    number: "02",
    title: "Architecture & IVR",
    text: "Complex IVR design, call-flow architecture, routing logic, integrations, and practical solution design.",
  },
  {
    number: "03",
    title: "Telephony & Integration",
    text: "SIP, CTI, CSTA, TAPI, call control, protocol analysis, and enterprise telephony integration.",
  },
  {
    number: "04",
    title: "Automation & Applied AI",
    text: "Workflow automation, APIs, RAG, MCP, agentic AI concepts, and practical AI-led support ideas.",
  },
];

const projects = [
  {
    title: "SupportBuddy",
    category: "AI Ticketing Intelligence",
    text: "A concept that brings together fragmented customer interactions across voice, email, and chat to give agents useful context.",
    href: "/projects/supportbuddy/",
  },
  {
    title: "Log Parser",
    category: "Technical Troubleshooting",
    text: "A practical project focused on making technical logs easier to interpret during issue investigation.",
    href: "/projects/log-parser/",
  },
  {
    title: "Vibeathon Innovation",
    category: "Mitel Innovation",
    text: "Applied AI and customer-support innovation work developed for the Mitel Vibeathon.",
    href: "/projects/innovation/",
  },
];
---

<BaseLayout
  title="Surya Lenka | UC, Contact Center & Applied AI"
  description="Portfolio of Surya Lenka, Team Lead for MCX and CloudLink with 20 years of experience in Unified Communications, Contact Center, solution architecture and applied AI."
>
  <section class="hero">
    <div class="hero-shell">
      <div class="hero-copy">
        <p class="eyebrow">
          <span></span>
          Bengaluru, India
        </p>

        <h1>
          Building reliable customer communication systems and practical AI solutions.
        </h1>

        <p class="hero-intro">
          I am Surya Lenka, a Technical Lead working across MCX and CloudLink.
          With 20 years of experience in Unified Communications and Contact Center
          technologies, I focus on complex systems, customer journeys, telephony,
          automation, and technical problem-solving.
        </p>

        <div class="hero-actions">
          <a class="primary-button" href="/profile/experience/">Explore my profile</a>
          <a class="secondary-button" href="/projects/">View projects</a>
        </div>
      </div>

      <aside class="hero-panel" aria-label="Professional summary">
        <p class="panel-label">Current focus</p>
        <h2>Team Lead, MCX & CloudLink</h2>

        <div class="panel-line"></div>

        <div class="panel-item">
          <strong>20 years</strong>
          <span>Unified Communications & Contact Center experience</span>
        </div>

        <div class="panel-item">
          <strong>HCL · Avaya · Mitel</strong>
          <span>Enterprise communication technology experience</span>
        </div>

        <div class="panel-item">
          <strong>Architecture · SIP · IVR · AI</strong>
          <span>Core technical and innovation areas</span>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="section-shell">
      <div class="section-heading">
        <div>
          <p class="section-label">Professional focus</p>
          <h2>Deep technical foundations. Practical outcomes.</h2>
        </div>

        <p>
          My work combines enterprise communication systems, architecture,
          telephony protocols, workflow design, technical leadership, and
          applied automation.
        </p>
      </div>

      <div class="expertise-grid">
        {expertise.map((item) => (
          <a class="expertise-card" href="/expertise/">
            <span class="card-number">{item.number}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <span class="card-link">Explore area →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section projects-section">
    <div class="section-shell">
      <div class="section-heading">
        <div>
          <p class="section-label">Projects & innovation</p>
          <h2>Ideas built around real support and customer experience problems.</h2>
        </div>

        <a class="text-link" href="/projects/">See all projects →</a>
      </div>

      <div class="projects-grid">
        {projects.map((project) => (
          <a class="project-card" href={project.href}>
            <p class="project-category">{project.category}</p>
            <h3>{project.title}</h3>
            <p>{project.text}</p>
            <span>Read more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="journey-section">
    <div class="journey-shell">
      <p class="section-label">Background</p>
      <h2>Two decades of enterprise communication technology.</h2>

      <div class="journey-grid">
        <div>
          <strong>Education</strong>
          <p>MS from BITS Pilani and B.Tech in Electronics and Telecommunication Engineering.</p>
        </div>

        <div>
          <strong>Certifications</strong>
          <p>AWS Certified Solutions Architect and Microsoft Certified Azure Administrator.</p>
        </div>

        <div>
          <strong>Beyond work</strong>
          <p>Exploring AI, automation, technical tools, and small creative projects such as Save the Baby Dragon.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 92px 0 78px;
    overflow: hidden;
    background:
      radial-gradient(circle at 86% 16%, rgba(196, 230, 208, 0.72), transparent 26rem),
      var(--page-bg);
  }

  .hero-shell,
  .section-shell,
  .journey-shell {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  .hero-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.65fr);
    gap: 64px;
    align-items: center;
  }

  .eyebrow,
  .section-label,
  .panel-label,
  .project-category {
    margin: 0;
    color: var(--green);
    font-family: "DM Mono", monospace;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .eyebrow {
    display: flex;
    align-items: center;
    gap: 9px;
  }

  .eyebrow span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 840px;
    margin: 20px 0 22px;
    font-size: clamp(2.8rem, 5.8vw, 5.3rem);
    line-height: 1.04;
    letter-spacing: -0.065em;
  }

  .hero-intro {
    max-width: 690px;
    margin-bottom: 32px;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .primary-button,
  .secondary-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 47px;
    padding: 0 18px;
    border-radius: 9px;
    font-size: 0.9rem;
    font-weight: 800;
    text-decoration: none;
    transition: 0.2s ease;
  }

  .primary-button {
    color: #ffffff;
    background: var(--green-dark);
  }

  .primary-button:hover {
    transform: translateY(-2px);
    background: var(--green);
  }

  .secondary-button {
    border: 1px solid var(--line);
    color: var(--text);
    background: #ffffff;
  }

  .secondary-button:hover {
    border-color: var(--green);
    color: var(--green);
  }

  .hero-panel {
    padding: 30px;
    border: 1px solid rgba(48, 93, 67, 0.16);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: var(--shadow);
  }

  .hero-panel h2 {
    margin: 12px 0 0;
    font-size: 1.45rem;
    line-height: 1.2;
    letter-spacing: -0.04em;
  }

  .panel-line {
    height: 1px;
    margin: 26px 0 8px;
    background: var(--line);
  }

  .panel-item {
    padding: 17px 0;
    border-bottom: 1px solid var(--line);
  }

  .panel-item:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .panel-item strong {
    display: block;
    margin-bottom: 4px;
    font-size: 0.94rem;
  }

  .panel-item span {
    display: block;
    color: var(--muted);
    font-size: 0.84rem;
    line-height: 1.5;
  }

  .section {
    padding: 88px 0;
  }

  .projects-section {
    border-top: 1px solid var(--line);
    background: #ffffff;
  }

  .section-heading {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 40px;
    margin-bottom: 34px;
  }

  .section-heading > div {
    max-width: 700px;
  }

  .section-heading h2,
  .journey-shell h2 {
    margin: 10px 0 0;
    font-size: clamp(2rem, 3.8vw, 3.15rem);
    line-height: 1.12;
    letter-spacing: -0.055em;
  }

  .section-heading > p {
    max-width: 370px;
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .expertise-grid,
  .projects-grid,
  .journey-grid {
    display: grid;
    gap: 16px;
  }

  .expertise-grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .expertise-card,
  .project-card {
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .expertise-card {
    min-height: 285px;
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 15px;
    color: var(--text);
    background: #ffffff;
  }

  .expertise-card:hover,
  .project-card:hover {
    transform: translateY(-4px);
    border-color: rgba(36, 114, 79, 0.4);
    box-shadow: var(--shadow);
  }

  .card-number {
    color: var(--green);
    font-family: "DM Mono", monospace;
    font-size: 0.76rem;
  }

  .expertise-card h3,
  .project-card h3 {
    margin: 28px 0 10px;
    font-size: 1.15rem;
    letter-spacing: -0.035em;
  }

  .expertise-card p,
  .project-card p {
    color: var(--muted);
    font-size: 0.89rem;
  }

  .card-link {
    display: inline-block;
    margin-top: 20px;
    color: var(--green);
    font-size: 0.84rem;
    font-weight: 800;
  }

  .text-link {
    color: var(--green);
    font-size: 0.9rem;
    font-weight: 800;
    text-decoration: none;
    white-space: nowrap;
  }

  .projects-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .project-card {
    min-height: 270px;
    padding: 26px;
    border: 1px solid var(--line);
    border-radius: 15px;
    color: var(--text);
    background: var(--page-bg);
  }

  .project-card h3 {
    margin-top: 22px;
  }

  .project-card > span {
    display: inline-block;
    margin-top: 19px;
    color: var(--green);
    font-size: 0.84rem;
    font-weight: 800;
  }

  .journey-section {
    padding: 88px 0;
    color: #ffffff;
    background: #18281f;
  }

  .journey-section .section-label {
    color: #a7d8bb;
  }

  .journey-shell h2 {
    max-width: 770px;
  }

  .journey-grid {
    grid-template-columns: repeat(3, 1fr);
    margin-top: 40px;
  }

  .journey-grid > div {
    padding: 20px 22px 0 0;
    border-top: 1px solid rgba(255, 255, 255, 0.22);
  }

  .journey-grid strong {
    font-size: 0.95rem;
  }

  .journey-grid p {
    margin: 10px 0 0;
    color: #c9d8cd;
    font-size: 0.9rem;
  }

  @media (max-width: 980px) {
    .hero-shell {
      grid-template-columns: 1fr;
      gap: 42px;
    }

    .hero-panel {
      max-width: 640px;
    }

    .expertise-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 720px) {
    .section-heading {
      display: block;
    }

    .section-heading > p {
      margin-top: 16px;
    }

    .text-link {
      display: inline-block;
      margin-top: 18px;
    }

    .projects-grid,
    .journey-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .hero,
    .section,
    .journey-section {
      padding: 64px 0;
    }

    .hero-shell,
    .section-shell,
    .journey-shell {
      width: min(100% - 28px, 1180px);
    }

    .hero-intro {
      font-size: 1rem;
    }

    .hero-actions a {
      width: 100%;
    }

    .expertise-grid {
      grid-template-columns: 1fr;
    }

    .hero-panel {
      padding: 24px;
    }
  }
</style>