---
import BaseLayout from "../layouts/BaseLayout.astro";

const contactOptions = [
  {
    label: "Email",
    value: "Available soon",
    text: "A professional email address will be added before the public launch.",
  },
  {
    label: "LinkedIn",
    value: "Profile link coming soon",
    text: "A direct LinkedIn profile link will be added here.",
  },
  {
    label: "Location",
    value: "Bengaluru, India",
    text: "Open to meaningful conversations around UC, Contact Center, AI, architecture, and technical leadership.",
  },
];
---

<BaseLayout
  title="Contact | Surya Lenka"
  description="Contact Surya Lenka for conversations around Unified Communications, Contact Center, technical architecture, automation, and applied AI."
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Contact</p>
      <h1>Let’s connect around meaningful technology problems.</h1>
      <p class="intro">
        I am interested in conversations around Unified Communications,
        Contact Center systems, technical architecture, AI-enabled workflows,
        automation, customer experience, and engineering leadership.
      </p>
    </div>
  </section>

  <section class="contact-section">
    <div class="shell contact-grid">
      <div>
        <p class="section-label">Get in touch</p>
        <h2>Professional contact details will live here.</h2>
        <p class="body-copy">
          This page is designed to grow into a full contact experience later.
          We can add a working email link, LinkedIn profile, contact form,
          API-based form handling, and automated notifications when you are ready.
        </p>
      </div>

      <div class="contact-list">
        {contactOptions.map((option) => (
          <article>
            <p class="label">{option.label}</p>
            <h3>{option.value}</h3>
            <p>{option.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="future-section">
    <div class="shell future-card">
      <div>
        <p class="section-label">Future-ready</p>
        <h2>Contact forms and backend integrations can be added later.</h2>
        <p>
          This page can later connect to Cloudflare Workers, email services,
          APIs, a CRM, or an AI assistant without changing the overall site structure.
        </p>
      </div>

      <span>Coming soon</span>
    </div>
  </section>
</BaseLayout>

<style>
  .shell {
    width: min(1080px, calc(100% - 40px));
    margin: 0 auto;
  }

  .page-hero {
    padding: 92px 0 70px;
    background:
      radial-gradient(circle at 84% 16%, rgba(196, 230, 208, 0.72), transparent 24rem),
      var(--page-bg);
  }

  .eyebrow,
  .section-label,
  .label {
    margin: 0;
    color: var(--green);
    font-family: "DM Mono", monospace;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 900px;
    margin: 16px 0 22px;
    font-size: clamp(2.7rem, 5.5vw, 4.8rem);
    line-height: 1.05;
    letter-spacing: -0.06em;
  }

  .intro {
    max-width: 760px;
    margin-bottom: 0;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .contact-section {
    padding: 84px 0;
    background: #ffffff;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.85fr);
    gap: 80px;
    align-items: start;
  }

  h2,
  .future-card h2 {
    margin: 10px 0 0;
    font-size: clamp(2rem, 3.8vw, 3.1rem);
    line-height: 1.12;
    letter-spacing: -0.05em;
  }

  .body-copy {
    max-width: 560px;
    margin: 20px 0 0;
    color: var(--muted);
  }

  .contact-list {
    display: grid;
    gap: 0;
  }

  .contact-list article {
    padding: 22px 0;
    border-bottom: 1px solid var(--line);
  }

  .contact-list article:first-child {
    padding-top: 0;
  }

  .contact-list h3 {
    margin: 9px 0 7px;
    font-size: 1.08rem;
    letter-spacing: -0.025em;
  }

  .contact-list p:not(.label) {
    margin-bottom: 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .future-section {
    padding: 84px 0;
    background: #18281f;
  }

  .future-card {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 28px;
    padding: 38px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 18px;
    color: #ffffff;
    background: #21342a;
  }

  .future-card .section-label {
    color: #a7d8bb;
  }

  .future-card h2 {
    font-size: 2rem;
  }

  .future-card p:not(.section-label) {
    max-width: 680px;
    margin: 14px 0 0;
    color: #c9d8cd;
  }

  .future-card span {
    flex: 0 0 auto;
    padding: 8px 11px;
    border-radius: 999px;
    color: #173422;
    background: #a7d8bb;
    font-size: 0.78rem;
    font-weight: 800;
  }

  @media (max-width: 760px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }

  @media (max-width: 620px) {
    .future-card {
      align-items: flex-start;
      flex-direction: column;
      padding: 26px;
    }
  }

  @media (max-width: 520px) {
    .shell {
      width: min(100% - 28px, 1080px);
    }

    .page-hero,
    .contact-section,
    .future-section {
      padding: 64px 0;
    }
  }
</style>