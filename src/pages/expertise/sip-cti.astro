---
import BaseLayout from "../../layouts/BaseLayout.astro";

const areas = [
  {
    title: "SIP Signalling",
    text: "Understanding SIP call setup, teardown, registration, routing, headers, SDP negotiation, and troubleshooting across enterprise communication environments.",
  },
  {
    title: "CTI Integration",
    text: "Working with computer telephony integration concepts that connect telephony events, agent workflows, desktop applications, and customer data.",
  },
  {
    title: "CSTA & TAPI",
    text: "Knowledge of telephony control and event models used to support call monitoring, call control, application integration, and agent workflows.",
  },
  {
    title: "Call Control & Events",
    text: "Understanding the events behind customer interactions, including inbound calls, transfers, holds, conferences, queue events, callbacks, and disconnect scenarios.",
  },
];

const troubleshootingFlow = [
  "Understand the expected customer or agent journey",
  "Identify where signalling, control, or integration behaviour differs",
  "Review call events, logs, traces, configuration, and dependencies",
  "Isolate the involved platform, service, device, or integration layer",
  "Validate the fix against the full call flow and operational outcome",
];
---

<BaseLayout
  title="SIP, CTI & Telephony Integration | Surya Lenka"
  description="SIP, CTI, CSTA, TAPI, call control, event handling, and enterprise telephony integration expertise of Surya Lenka."
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Expertise · 03</p>
      <h1>SIP, CTI, call control, and enterprise telephony integration.</h1>
      <p class="intro">
        Communication platforms become useful when signalling, call events,
        business workflows, applications, and customer journeys work together
        reliably. My focus is on understanding those layers end to end.
      </p>
    </div>
  </section>

  <section class="content-section">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="section-label">Integration perspective</p>
          <h2>Understanding what happens behind every customer interaction.</h2>
        </div>

        <p>
          A call may look simple to a user, but behind it are signalling
          exchanges, routing decisions, application events, device states,
          platform services, integrations, and customer workflow logic.
        </p>
      </div>

      <div class="area-grid">
        {areas.map((area, index) => (
          <article class="area-card">
            <span>0{index + 1}</span>
            <h3>{area.title}</h3>
            <p>{area.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="telephony-section">
    <div class="shell telephony-layout">
      <div>
        <p class="section-label">Core knowledge areas</p>
        <h2>Technical depth across the telephony and application boundary.</h2>
      </div>

      <div class="tag-list">
        <span>SIP signalling</span>
        <span>Call setup & teardown</span>
        <span>Registration</span>
        <span>SDP negotiation</span>
        <span>CTI events</span>
        <span>CSTA</span>
        <span>TAPI</span>
        <span>Call monitoring</span>
        <span>Call control</span>
        <span>Transfers & conferences</span>
        <span>Agent state events</span>
        <span>Telephony troubleshooting</span>
      </div>
    </div>
  </section>

  <section class="workflow-section">
    <div class="shell workflow-layout">
      <div>
        <p class="section-label">Troubleshooting approach</p>
        <h2>Follow the interaction, not just the symptom.</h2>
        <p>
          Telephony issues are often spread across multiple layers. Effective
          troubleshooting means following the customer interaction from entry
          point through routing, signalling, integration, application events,
          and final outcome.
        </p>
      </div>

      <div class="workflow-list">
        {troubleshootingFlow.map((step, index) => (
          <div class="workflow-step">
            <span>{index + 1}</span>
            <p>{step}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="next-section">
    <div class="shell next-card">
      <div>
        <p class="section-label">Next expertise area</p>
        <h2>Systems, Networking & Platform Operations</h2>
        <p>
          Explore the infrastructure, operating systems, services, networking,
          and platform dependencies behind enterprise communication systems.
        </p>
      </div>

      <a href="/expertise/systems-networking/">Explore Systems & Networking →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .shell {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
  }

  .page-hero {
    padding: 92px 0 70px;
    background:
      radial-gradient(circle at 84% 16%, rgba(196, 230, 208, 0.72), transparent 24rem),
      var(--page-bg);
  }

  .eyebrow,
  .section-label {
    margin: 0;
    color: var(--green);
    font-family: "DM Mono", monospace;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 940px;
    margin: 16px 0 22px;
    font-size: clamp(2.7rem, 5.5vw, 4.8rem);
    line-height: 1.05;
    letter-spacing: -0.06em;
  }

  .intro {
    max-width: 780px;
    margin-bottom: 0;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .content-section {
    padding: 84px 0 96px;
    background: #ffffff;
  }

  .section-heading {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.65fr);
    gap: 64px;
    align-items: end;
    margin-bottom: 40px;
  }

  .section-heading h2,
  .telephony-layout h2,
  .workflow-layout h2,
  .next-card h2 {
    margin: 10px 0 0;
    font-size: clamp(2rem, 3.8vw, 3.1rem);
    line-height: 1.12;
    letter-spacing: -0.05em;
  }

  .section-heading > p {
    margin: 0;
    color: var(--muted);
  }

  .area-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }

  .area-card {
    min-height: 235px;
    padding: 27px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--page-bg);
  }

  .area-card > span {
    color: var(--green);
    font-family: "DM Mono", monospace;
    font-size: 0.76rem;
  }

  .area-card h3 {
    margin: 24px 0 10px;
    font-size: 1.18rem;
    line-height: 1.2;
    letter-spacing: -0.035em;
  }

  .area-card p {
    margin-bottom: 0;
    color: var(--muted);
    font-size: 0.91rem;
  }

  .telephony-section {
    padding: 84px 0;
    background: var(--page-bg);
  }

  .telephony-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(320px, 0.9fr);
    gap: 80px;
    align-items: start;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tag-list span {
    padding: 9px 12px;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: #375143;
    background: #ffffff;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .workflow-section {
    padding: 84px 0;
    color: #ffffff;
    background: #18281f;
  }

  .workflow-section .section-label {
    color: #a7d8bb;
  }

  .workflow-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.8fr);
    gap: 80px;
    align-items: start;
  }

  .workflow-layout > div > p:not(.section-label) {
    max-width: 540px;
    margin: 18px 0 0;
    color: #c9d8cd;
  }

  .workflow-list {
    display: grid;
    gap: 14px;
  }

  .workflow-step {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 15px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
  }

  .workflow-step span {
    display: grid;
    width: 28px;
    height: 28px;
    flex: 0 0 28px;
    place-items: center;
    border-radius: 50%;
    color: #18281f;
    background: #a7d8bb;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .workflow-step p {
    margin: 2px 0 0;
    color: #d8e3db;
    font-size: 0.93rem;
  }

  .next-section {
    padding: 84px 0;
    background: #ffffff;
  }

  .next-card {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 28px;
    padding: 38px;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: var(--page-bg);
  }

  .next-card h2 {
    font-size: 2rem;
  }

  .next-card p:not(.section-label) {
    max-width: 650px;
    margin: 14px 0 0;
    color: var(--muted);
  }

  .next-card a {
    flex: 0 0 auto;
    padding: 13px 17px;
    border-radius: 9px;
    color: #ffffff;
    background: var(--green-dark);
    font-size: 0.88rem;
    font-weight: 800;
    text-decoration: none;
  }

  .next-card a:hover {
    background: var(--green);
  }

  @media (max-width: 860px) {
    .section-heading,
    .telephony-layout,
    .workflow-layout {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }

  @media (max-width: 620px) {
    .area-grid {
      grid-template-columns: 1fr;
    }

    .next-card {
      align-items: flex-start;
      flex-direction: column;
      padding: 26px;
    }
  }

  @media (max-width: 520px) {
    .shell {
      width: min(100% - 28px, 1120px);
    }

    .page-hero,
    .content-section,
    .telephony-section,
    .workflow-section,
    .next-section {
      padding: 64px 0;
    }
  }
</style>