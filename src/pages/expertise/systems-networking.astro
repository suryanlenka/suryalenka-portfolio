---
import BaseLayout from "../../layouts/BaseLayout.astro";

const areas = [
  {
    title: "Enterprise Networking",
    text: "Understanding the network layers that support enterprise communication systems, including connectivity, routing, DNS, firewall dependencies, ports, and service reachability.",
  },
  {
    title: "Linux Environments",
    text: "Working with Linux-based applications, services, logs, processes, permissions, configuration files, and operational troubleshooting.",
  },
  {
    title: "Windows Services",
    text: "Experience with Windows-based services, service dependencies, application behaviour, event logs, startup conditions, and platform troubleshooting.",
  },
  {
    title: "Platform Dependencies",
    text: "Understanding how servers, databases, APIs, certificates, network access, services, and integrations affect the behaviour of communication platforms.",
  },
];

const troubleshootingSteps = [
  "Confirm the customer-visible symptom and expected behaviour",
  "Identify the affected service, server, application, network path, or dependency",
  "Review logs, service state, connectivity, configuration, and recent changes",
  "Separate root cause from secondary symptoms",
  "Validate recovery and confirm the full platform behaviour",
];

const operatingAreas = [
  "Service health and dependencies",
  "Application and system logs",
  "Networking and connectivity",
  "Certificates and secure communication",
  "Windows and Linux service behaviour",
  "Platform configuration and environment differences",
];
---

<BaseLayout
  title="Systems, Networking & Platform Operations | Surya Lenka"
  description="Systems, networking, Linux, Windows services, infrastructure dependencies, and platform operations expertise of Surya Lenka."
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Expertise · 04</p>
      <h1>Systems, networking, and the platform layers behind communication services.</h1>
      <p class="intro">
        Reliable communication platforms depend on more than applications alone.
        Networking, operating systems, services, security, dependencies, and
        infrastructure all play a role in the customer experience.
      </p>
    </div>
  </section>

  <section class="content-section">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="section-label">Platform perspective</p>
          <h2>Understand the environment, not just the application.</h2>
        </div>

        <p>
          Many enterprise communication issues cross multiple technical layers.
          Effective problem-solving requires knowing how infrastructure,
          services, connectivity, and applications influence one another.
        </p>
      </div>

      <div class="area-grid">
        {areas.map((area, index) => (
          <article class="area-card">
            <span>0{index + 1}</span>
            <h3>{area.title}</h3>
            <p>{area.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="operations-section">
    <div class="shell operations-layout">
      <div>
        <p class="section-label">Operational focus</p>
        <h2>Platform reliability starts with visibility across the full environment.</h2>
      </div>

      <div class="operations-list">
        {operatingAreas.map((item) => (
          <div>
            <span>✓</span>
            <p>{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="workflow-section">
    <div class="shell workflow-layout">
      <div>
        <p class="section-label">Troubleshooting method</p>
        <h2>Trace the issue through the right technical layers.</h2>
        <p>
          The goal is not only to restore service, but to understand what
          changed, why it changed, and how the platform can be made more
          reliable going forward.
        </p>
      </div>

      <div class="workflow-list">
        {troubleshootingSteps.map((step, index) => (
          <div class="workflow-step">
            <span>{index + 1}</span>
            <p>{step}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="next-section">
    <div class="shell next-card">
      <div>
        <p class="section-label">Next expertise area</p>
        <h2>DevOps & Engineering Automation</h2>
        <p>
          Explore source control, containers, CI/CD, configuration automation,
          deployment practices, and modern engineering workflows.
        </p>
      </div>

      <a href="/expertise/devops-automation/">Explore DevOps & Automation →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .shell {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
  }

  .page-hero {
    padding: 92px 0 70px;
    background:
      radial-gradient(circle at 84% 16%, rgba(196, 230, 208, 0.72), transparent 24rem),
      var(--page-bg);
  }

  .eyebrow,
  .section-label {
    margin: 0;
    color: var(--green);
    font-family: "DM Mono", monospace;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 950px;
    margin: 16px 0 22px;
    font-size: clamp(2.7rem, 5.5vw, 4.8rem);
    line-height: 1.05;
    letter-spacing: -0.06em;
  }

  .intro {
    max-width: 790px;
    margin-bottom: 0;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .content-section {
    padding: 84px 0 96px;
    background: #ffffff;
  }

  .section-heading {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.65fr);
    gap: 64px;
    align-items: end;
    margin-bottom: 40px;
  }

  .section-heading h2,
  .operations-layout h2,
  .workflow-layout h2,
  .next-card h2 {
    margin: 10px 0 0;
    font-size: clamp(2rem, 3.8vw, 3.1rem);
    line-height: 1.12;
    letter-spacing: -0.05em;
  }

  .section-heading > p {
    margin: 0;
    color: var(--muted);
  }

  .area-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }

  .area-card {
    min-height: 235px;
    padding: 27px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--page-bg);
  }

  .area-card > span {
    color: var(--green);
    font-family: "DM Mono", monospace;
    font-size: 0.76rem;
  }

  .area-card h3 {
    margin: 24px 0 10px;
    font-size: 1.18rem;
    line-height: 1.2;
    letter-spacing: -0.035em;
  }

  .area-card p {
    margin-bottom: 0;
    color: var(--muted);
    font-size: 0.91rem;
  }

  .operations-section {
    padding: 84px 0;
    background: var(--page-bg);
  }

  .operations-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.8fr);
    gap: 80px;
    align-items: start;
  }

  .operations-list {
    display: grid;
    gap: 13px;
  }

  .operations-list div {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
  }

  .operations-list span {
    color: var(--green);
    font-weight: 800;
  }

  .operations-list p {
    margin: 0;
    color: #405047;
    font-size: 0.93rem;
  }

  .workflow-section {
    padding: 84px 0;
    color: #ffffff;
    background: #18281f;
  }

  .workflow-section .section-label {
    color: #a7d8bb;
  }

  .workflow-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.8fr);
    gap: 80px;
    align-items: start;
  }

  .workflow-layout > div > p:not(.section-label) {
    max-width: 540px;
    margin: 18px 0 0;
    color: #c9d8cd;
  }

  .workflow-list {
    display: grid;
    gap: 14px;
  }

  .workflow-step {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 15px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
  }

  .workflow-step span {
    display: grid;
    width: 28px;
    height: 28px;
    flex: 0 0 28px;
    place-items: center;
    border-radius: 50%;
    color: #18281f;
    background: #a7d8bb;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .workflow-step p {
    margin: 2px 0 0;
    color: #d8e3db;
    font-size: 0.93rem;
  }

  .next-section {
    padding: 84px 0;
    background: #ffffff;
  }

  .next-card {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 28px;
    padding: 38px;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: var(--page-bg);
  }

  .next-card h2 {
    font-size: 2rem;
  }

  .next-card p:not(.section-label) {
    max-width: 650px;
    margin: 14px 0 0;
    color: var(--muted);
  }

  .next-card a {
    flex: 0 0 auto;
    padding: 13px 17px;
    border-radius: 9px;
    color: #ffffff;
    background: var(--green-dark);
    font-size: 0.88rem;
    font-weight: 800;
    text-decoration: none;
  }

  .next-card a:hover {
    background: var(--green);
  }

  @media (max-width: 860px) {
    .section-heading,
    .operations-layout,
    .workflow-layout {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }

  @media (max-width: 620px) {
    .area-grid {
      grid-template-columns: 1fr;
    }

    .next-card {
      align-items: flex-start;
      flex-direction: column;
      padding: 26px;
    }
  }

  @media (max-width: 520px) {
    .shell {
      width: min(100% - 28px, 1120px);
    }

    .page-hero,
    .content-section,
    .operations-section,
    .workflow-section,
    .next-section {
      padding: 64px 0;
    }
  }
</style>