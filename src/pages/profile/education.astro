---
import BaseLayout from "../../layouts/BaseLayout.astro";

const education = [
  {
    degree: "Master of Science",
    institution: "BITS Pilani",
    description:
      "Advanced academic study supporting a strong foundation in technology, systems thinking, and engineering leadership.",
  },
  {
    degree: "Bachelor of Technology",
    institution: "Electronics and Telecommunication Engineering",
    description:
      "Engineering foundation in electronics, communication systems, networking, and telecommunications.",
  },
];
---

<BaseLayout
  title="Education | Surya Lenka"
  description="Education background of Surya Lenka, including an MS from BITS Pilani and a B.Tech in Electronics and Telecommunication Engineering."
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Profile</p>
      <h1>Academic foundations for a career in communication technology.</h1>
      <p class="intro">
        My education built the technical base behind my work in enterprise
        communications, networking, contact center systems, and solution design.
      </p>
    </div>
  </section>

  <section class="education-section">
    <div class="shell">
      <div class="education-list">
        {education.map((item, index) => (
          <article class="education-card">
            <span class="number">0{index + 1}</span>

            <div>
              <p class="label">Education</p>
              <h2>{item.degree}</h2>
              <h3>{item.institution}</h3>
              <p class="description">{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .shell {
    width: min(980px, calc(100% - 40px));
    margin: 0 auto;
  }

  .page-hero {
    padding: 92px 0 70px;
    background:
      radial-gradient(circle at 82% 14%, rgba(196, 230, 208, 0.72), transparent 23rem),
      var(--page-bg);
  }

  .eyebrow,
  .label,
  .number {
    margin: 0;
    color: var(--green);
    font-family: "DM Mono", monospace;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 820px;
    margin: 16px 0 22px;
    font-size: clamp(2.7rem, 5.5vw, 4.8rem);
    line-height: 1.05;
    letter-spacing: -0.06em;
  }

  .intro {
    max-width: 720px;
    margin-bottom: 0;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .education-section {
    padding: 82px 0 96px;
    background: #ffffff;
  }

  .education-list {
    display: grid;
    gap: 18px;
  }

  .education-card {
    display: grid;
    grid-template-columns: 74px 1fr;
    gap: 28px;
    padding: 32px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--page-bg);
  }

  .number {
    padding-top: 4px;
  }

  .label {
    margin-bottom: 12px;
  }

  h2 {
    margin-bottom: 8px;
    font-size: 1.5rem;
    line-height: 1.2;
    letter-spacing: -0.04em;
  }

  h3 {
    margin-bottom: 16px;
    color: #405047;
    font-size: 0.96rem;
  }

  .description {
    max-width: 680px;
    margin-bottom: 0;
    color: var(--muted);
  }

  @media (max-width: 520px) {
    .shell {
      width: min(100% - 28px, 980px);
    }

    .page-hero,
    .education-section {
      padding: 64px 0;
    }

    .education-card {
      grid-template-columns: 1fr;
      gap: 15px;
      padding: 24px;
    }
  }
</style>