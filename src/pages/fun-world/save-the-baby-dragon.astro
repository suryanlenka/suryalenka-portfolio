---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Save the Baby Dragon | Surya Lenka"
  description="A fun browser game: help a baby dragon collect magical gems and dodge angry birds."
>
  <section class="game-page">
    <iframe
      src="/fun-world/save-the-baby-dragon/index.html"
      title="Save the Baby Dragon game"
      allow="autoplay"
    ></iframe>
  </section>
</BaseLayout>

<style>
  .game-page {
    width: 100%;
    height: calc(100vh - 85px);
    min-height: 650px;
    background: #7ec8ff;
  }

  iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media (max-width: 700px) {
    .game-page {
      height: calc(100vh - 72px);
      min-height: 580px;
    }
  }
</style>