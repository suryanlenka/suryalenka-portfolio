---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="The Haunted Mansion | Surya Lenka"
  description="A family-friendly spooky browser game: collect lost lanterns and explore the Haunted Mansion."
>
  <section class="game-page">
    <iframe
      src="/fun-world/haunted-mansion/index.html"
      title="The Haunted Mansion game"
      allow="autoplay"
    ></iframe>
  </section>
</BaseLayout>

<style>
  .game-page {
    width: 100%;
    height: calc(100vh - 85px);
    min-height: 650px;
    background: #10101f;
  }

  iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media (max-width: 700px) {
    .game-page {
      height: calc(100vh - 72px);
      min-height: 580px;
    }
  }
</style>