---
import BaseLayout from "../../layouts/BaseLayout.astro";

const ideas = [
  {
    number: "01",
    title: "Save the Baby Dragon",
    text: "A small family-friendly browser game created as a creative project for my daughter.",
    status: "Coming soon",
  },
  {
    number: "02",
    title: "Interactive Learning Games",
    text: "Future mini-games and playful experiments that combine creativity, storytelling, and simple technology.",
    status: "Future idea",
  },
  {
    number: "03",
    title: "Creative AI Experiments",
    text: "Small visual, storytelling, and AI-assisted projects built for curiosity and fun.",
    status: "Future idea",
  },
];
---

<BaseLayout
  title="Fun World | Surya Lenka"
  description="Fun World by Surya Lenka, featuring creative experiments, family-friendly games, and future AI projects."
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Fun world</p>
      <h1>Small projects made for curiosity, creativity, and joy.</h1>
      <p class="intro">
        Not every project needs to solve an enterprise problem. This space is
        for family-friendly games, creative experiments, and ideas built simply
        because they are enjoyable to make.
      </p>
    </div>
  </section>

  <section class="projects-section">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="section-label">Creative projects</p>
          <h2>A lighter side of building things.</h2>
        </div>

        <p>
          These projects are separate from my professional work and will grow
          over time as new ideas become real.
        </p>
      </div>

      <div class="projects-grid">
        {ideas.map((idea) => (
          <article class="project-card">
            <div class="card-top">
              <span>{idea.number}</span>
              <small>{idea.status}</small>
            </div>

            <div class="dragon-icon" aria-hidden="true">
              {idea.number === "01" ? "🐉" : idea.number === "02" ? "🎮" : "✨"}
            </div>

            <h3>{idea.title}</h3>
            <p>{idea.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="highlight-section">
    <div class="shell highlight-card">
      <div>
        <p class="section-label">Featured future project</p>
        <h2>Save the Baby Dragon</h2>
        <p>
          A playful browser game being prepared for a clean standalone release.
          Once it is ready, this page will link directly to the live game.
        </p>
      </div>

      <span class="status-pill">Coming soon</span>
    </div>
  </section>
</BaseLayout>

<style>
  .shell {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
  }

  .page-hero {
    padding: 92px 0 70px;
    background:
      radial-gradient(circle at 84% 16%, rgba(196, 230, 208, 0.72), transparent 24rem),
      var(--page-bg);
  }

  .eyebrow,
  .section-label {
    margin: 0;
    color: var(--green);
    font-family: "DM Mono", monospace;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 920px;
    margin: 16px 0 22px;
    font-size: clamp(2.7rem, 5.5vw, 4.8rem);
    line-height: 1.05;
    letter-spacing: -0.06em;
  }

  .intro {
    max-width: 780px;
    margin-bottom: 0;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .projects-section {
    padding: 84px 0 96px;
    background: #ffffff;
  }

  .section-heading {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.65fr);
    gap: 64px;
    align-items: end;
    margin-bottom: 40px;
  }

  .section-heading h2,
  .highlight-card h2 {
    margin: 10px 0 0;
    font-size: clamp(2rem, 3.8vw, 3.1rem);
    line-height: 1.12;
    letter-spacing: -0.05em;
  }

  .section-heading > p {
    margin: 0;
    color: var(--muted);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .project-card {
    min-height: 315px;
    padding: 28px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--page-bg);
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-top > span {
    color: var(--green);
    font-family: "DM Mono", monospace;
    font-size: 0.76rem;
  }

  .card-top small,
  .status-pill {
    padding: 6px 10px;
    border-radius: 999px;
    color: #355142;
    background: var(--green-soft);
    font-size: 0.74rem;
    font-weight: 800;
  }

  .dragon-icon {
    margin-top: 34px;
    font-size: 2rem;
  }

  .project-card h3 {
    margin: 20px 0 10px;
    font-size: 1.28rem;
    letter-spacing: -0.04em;
  }

  .project-card p {
    margin-bottom: 0;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .highlight-section {
    padding: 84px 0;
    background: #18281f;
  }

  .highlight-card {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 28px;
    padding: 38px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 18px;
    color: #ffffff;
    background: #21342a;
  }

  .highlight-card .section-label {
    color: #a7d8bb;
  }

  .highlight-card h2 {
    font-size: 2rem;
  }

  .highlight-card p:not(.section-label) {
    max-width: 690px;
    margin: 14px 0 0;
    color: #c9d8cd;
  }

  .status-pill {
    flex: 0 0 auto;
    color: #173422;
    background: #a7d8bb;
  }

  @media (max-width: 850px) {
    .section-heading {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .highlight-card {
      align-items: flex-start;
      flex-direction: column;
      padding: 26px;
    }
  }

  @media (max-width: 520px) {
    .shell {
      width: min(100% - 28px, 1120px);
    }

    .page-hero,
    .projects-section,
    .highlight-section {
      padding: 64px 0;
    }
  }
</style>